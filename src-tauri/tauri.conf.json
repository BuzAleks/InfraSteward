{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "InfraSteward",
  "version": "0.1.0",
  "identifier": "dev.infrasteward.desktop",
  "build": {
    "beforeDevCommand": "npm run web:dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run web:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "InfraSteward",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "dmg", "appimage", "deb"],
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
